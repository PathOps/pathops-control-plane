export DB_CONNECTION_URL=jdbc:postgresql://localhost:5432/pathops_control_plane
export DB_USERNAME=admin
export DB_PASSWORD=admin
export HIBERNATE_DDL_AUTO=validate
export JPA_SHOW_SQL=true
export PATHOPS_AUTH_JWK_SET_URI=https://keycloak.demo.pathops.io/realms/pathops/protocol/openid-connect/certs
export PATHOPS_VAULT_BASE_URL=https://vault.demo.pathops.io
export PATHOPS_DEMO_BOOTSTRAP_ENABLED=true
export PATHOPS_DEMO_TOOLS_KEYCLOAK_BASE_URL=https://keycloak.demo.pathops.io
export PATHOPS_DEMO_TOOLS_JENKINS_BASE_URL=https://jenkins.demo.pathops.io

if [ -f .envrc.local ]; then
  source_env .envrc.local
fi
